{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npx vite --port $PORT",
  "functions": {
    "api/translate.ts": {
      "maxDuration": 30
    },
    "api/realtime-token.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
